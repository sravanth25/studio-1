{
  "buildCommand": "pnpm --filter @workspace/jaaga run build:vercel && cp -r artifacts/jaaga/dist ./dist",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
